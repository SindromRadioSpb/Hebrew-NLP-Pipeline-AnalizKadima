# .env.example — KADIMA environment variables
# Copy to .env and fill in actual values
# NEVER commit .env to git

# ── Label Studio ─────────────────────────────────────────────────────────────
LS_API_KEY=
LABEL_STUDIO_USERNAME=admin
LABEL_STUDIO_PASSWORD=

# ── Model cache paths (optional, defaults to ~/.cache) ───────────────────────
# HF_HOME=F:/huggingface
# TORCH_HOME=F:/datasets_models/torch
# TRANSFORMERS_CACHE=F:/datasets_models/transformers

# ── Local model paths (override auto-discovery) ──────────────────────────────
# WHISPER_MODEL_PATH=F:/datasets_models/stt/whisper-large-v3-turbo/large-v3-turbo.pt
# FASTER_WHISPER_MODEL_PATH=F:/datasets_models/stt/whisper-large-v3-turbo-he/models--ivrit-ai--whisper-large-v3-turbo-ct2/snapshots/...
# MMS_TTS_MODEL_PATH=F:/datasets_models/tts/mms-tts-heb/models--facebook--mms-tts-heb/snapshots/...
# PHONIKUD_ONNX_MODEL_PATH=F:/datasets_models/phonikud/phonikud-1.0.int8.onnx

# ── KADIMA runtime ───────────────────────────────────────────────────────────
# KADIMA_HOME=/data
# KADIMA_LOG_LEVEL=INFO
