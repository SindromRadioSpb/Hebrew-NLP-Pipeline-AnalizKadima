# .env.example — KADIMA environment variables
# Copy to .env and fill in actual values
# NEVER commit .env to git

# ── Label Studio ─────────────────────────────────────────────────────────────
LS_API_KEY=
LABEL_STUDIO_USERNAME=admin
LABEL_STUDIO_PASSWORD=

# ── Model cache paths (optional, defaults to ~/.cache) ───────────────────────
# HF_HOME=F:/datasets_models
# TORCH_HOME=F:/datasets_models/torch
# TRANSFORMERS_CACHE=F:/datasets_models/transformers

# ── KADIMA runtime ───────────────────────────────────────────────────────────
# KADIMA_HOME=/data
# KADIMA_LOG_LEVEL=INFO
