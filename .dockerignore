# .dockerignore — exclude from Docker build context

# Git
.git/
.gitignore

# Python caches
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/

# Virtual envs
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Tests & validation data (not needed in image)
tests/
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Linter / type caches
.mypy_cache/
.ruff_cache/

# Secrets — never bake into image
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db
desktop.ini

# Large data / models
*.db
*.sqlite
*.sqlite3
*.gguf
*.bin
*.onnx
models/
hebrew-nlp-resources/

# Docs (not needed in runtime)
doc/
*.md
!config/*.md
LICENSE

# Docker meta
docker-compose*.yml
.dockerignore
Makefile

# Tasks / dev planning
Tasks/

# CI
.github/
