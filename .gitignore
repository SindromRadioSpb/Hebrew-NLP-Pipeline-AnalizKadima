# .gitignore — KADIMA

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual envs
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Pytest / Coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml
results.xml

# Linter / type caches
.mypy_cache/
.ruff_cache/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Secrets — NEVER commit
.env
.env.local
.env.production

# SQLite databases (runtime data)
*.db
*.sqlite
*.sqlite3

# Models (large binaries, downloaded separately)
*.gguf
*.bin
*.onnx
*.pt
*.safetensors
models/

# Audio outputs (generated by TTS)
output_audio/
*.wav
*.mp3
*.flac

# HuggingFace / Torch caches
.cache/

# KADIMA runtime
logs/
backups/
exports/

# Docker volumes (local)
docker-data/
